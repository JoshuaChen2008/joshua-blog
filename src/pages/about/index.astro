---
import { Button, Collapse, Spoiler, Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import Substats from '@/components/about/Substats.astro'
import ToolSection from '@/components/about/ToolSection.astro'

const headings = [
  { depth: 2, slug: 'hobbies', text: 'Hobbies' },
  { depth: 2, slug: 'tools', text: 'Tools' },
  { depth: 2, slug: 'social-networks', text: 'Social Networks' },
 /* { depth: 2, slug: 'gossips', text: 'Gossips' },*/
  { depth: 2, slug: 'about-blog', text: 'About Blog' }
]
---

<PageLayout title='About' {headings} comment highlightColor='#659EB9' highlightTone='soft'>
  <p>AI Agent & Full-Stack Developer</p>
  <p>
    天津理工大学在读，目前为大一学生，致力于研究和开发有用且有趣的产品，正在学习LLM和Agent开发，喜欢将新技术用于工程实践中，在意产品能不能真正跑起来，也在意市场的反馈
    <p><Spoiler>请给我更多的米吧我什么都会做的</Spoiler></p>
  </p>
  <p>
    Motto: For friends and tomorrow <Spoiler> and you ❤️</Spoiler>
  </p>
 {/* <Button title='Sponsor Me' class='w-fit' href='/projects#sponsorship' variant='ahead' />*/} 

  {/* general-talk */}
  <h2 id='hobbies'>Hobbies</h2>
  <ul>
    <li><strong>虚拟摄影 Virtual Photography</strong> - 喜欢在Vrchat或是Unity等软件内进行类摄影的创作</li>
    <li>
      <strong>开源贡献 Open Source </strong> - 致力于成为一名活跃的开源贡献者，通过代码和社区交流不断学习和成长。
    </li>
   <li> <strong>电脑DIY Computer DIY </strong> - 喜欢自己折腾电子设备，积极关注新兴电子产品</li>
  </ul>

