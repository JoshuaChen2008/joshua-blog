---
/**
 * Note Module - /note
 * This is a knowledge base for ideas, snippets, and semi-finished materials.
 * Note: This is different from /archives (plural) which shows blog posts grouped by year.
 */
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'
import { getCollection } from 'astro:content'

import { Paginator } from 'astro-pure/components/pages'
import { Button, Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import NotePreview from '@/components/notes/NotePreview.astro'
import { PageInfo } from '@/components/waline'

import { statusColors, statusLabels } from '../../lib/noteMeta'

export const prerender = true

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const allNotes = await getCollection('note')
  const sortedNotes = allNotes
    .filter((entry) => !entry.data.draft)
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())

  return paginate(sortedNotes, {
    pageSize: 20
  })
}

interface Props {
  page: Page<CollectionEntry<'note'>>
}

const { page } = Astro.props as unknown as Props

const allNotes = (await getCollection('note')).filter((entry) => !entry.data.draft)
const uniqueTags = [...new Set(allNotes.flatMap((entry) => entry.data.tags))].sort()
const uniqueStatuses = [...new Set(allNotes.map((entry) => entry.data.status))].sort()

const statusCounts = allNotes.reduce(
  (acc, entry) => {
    acc[entry.data.status] = (acc[entry.data.status] || 0) + 1
    return acc
  },
  {} as Record<string, number>
)

const meta = {
  description: 'Agent 学习、工程化选型对比、面试题笔记——未成稿，但都是一手思考',
  title: page.currentPage === 1 ? 'Notes' : `Notes - Page ${page.currentPage}`
}

const paginationProps = {
  ...(page.url.prev && {
    prevUrl: {
      text: '← 上一页',
      url: page.url.prev
    }
  }),
  ...(page.url.next && {
    nextUrl: {
      text: '下一页 →',
      url: page.url.next
    }
  })
}
---

<PageLayout {meta}>
  <Button title='Back' href='/' variant='back' />

  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <div class='mb-3 flex items-center gap-3'>
        <div>
          <h1 class='text-3xl font-medium'>Notes</h1>
          <p class='text-sm text-muted-foreground'></p>
        </div>
      </div>
      <p class='max-w-3xl text-muted-foreground'>一些杂碎的笔记</p>
      <PageInfo class='mt-3 italic' />
    </div>

    {
      page.data.length === 0 ? (
        <p class='mt-8'>No notes yet.</p>
      ) : (
        <div class='mt-10 grid gap-y-16 sm:grid-cols-[3fr_1fr] sm:gap-x-8'>
          <section id='content' class='animate' aria-label='Note entries'>
            <div class='mb-3 flex flex-col justify-between text-sm text-muted-foreground sm:mb-5 sm:flex-row'>
              <span>
                Page {page.start + 1} - Showing {page.end + 1} of {page.total} posts
              </span>
              {page.lastPage > 1 && (
                <span>
                  第 {page.currentPage} / {page.lastPage} 页
                </span>
              )}
            </div>

            <ul class='flex flex-col gap-y-4 text-start'>
              {page.data.map((entry) => (
                <NotePreview {entry} />
              ))}
            </ul>

            {page.lastPage > 1 && (
              <div class='mt-8'>
                <Paginator {...paginationProps} />
              </div>
            )}
          </section>

          <aside class='animate' id='sidebar'>
            {!!uniqueTags.length && (
              <section class='mb-8'>
                <div class='mb-4 flex items-center justify-between'>
                  <h2 class='flex items-center text-lg font-semibold'>
                    <Icon name='tag-2' class='me-2' />
                    Tags
                  </h2>
                  <a href='/note/tags' class='text-xs text-muted-foreground hover:text-foreground'>
                    查看全部 →
                  </a>
                </div>
                <ul class='flex flex-wrap gap-2'>
                  {uniqueTags.map((tag) => (
                    <li>
                      <a
                        href={`/note/tags/${tag}`}
                        class='inline-flex rounded-md border border-border px-2 py-1 text-xs transition hover:border-foreground/20'
                      >
                        {tag}
                      </a>
                    </li>
                  ))}
                </ul>
              </section>
            )}

            <section>
              <h2 class='mb-4 flex items-center text-lg font-semibold'>
                <Icon name='list' class='me-2' />
                Status
              </h2>
              <ul class='space-y-5 text-sm'>
                {uniqueStatuses.map((status) => (
                  <li class='flex items-center justify-between gap-3'>
                    <span class='flex items-center gap-2'>
                      <a
                        href={`/note/status/${status}`}
                        class={`rounded-md px-2 py-0.5 text-xs font-medium transition hover:opacity-80        
                      ${statusColors[status] || 'bg-gray-100 text-gray-600 dark:bg-gray-800/30 dark:text-gray-400'}`}
                      >
                        {statusLabels[status] || status}
                      </a>{' '}
                    </span>
                    <span class='text-xs text-muted-foreground'>{statusCounts[status] || 0}</span>
                  </li>
                ))}
              </ul>
            </section>
          </aside>
        </div>
      )
    }
  </main>
</PageLayout>
