---
import { Image } from 'astro:assets'
import { render, type CollectionEntry } from 'astro:content'
import { getCollection } from 'astro:content'
import PageLayout from '@/layouts/ContentLayout.astro'
import { PageInfo } from '@/components/waline'
import { Button, Icon } from 'astro-pure/user'

export const prerender = true

export async function getStaticPaths() {
  const notes = await getCollection('note')
  return notes.map((entry) => ({
    params: { id: entry.id },
    props: { entry }
  }))
}

type Props = {
  entry: CollectionEntry<'note'>
}

const { entry } = Astro.props
const { Content } = await render(entry)

const {
  title,
  description,
  accentColor,
  heroImage,
  date,
  updatedDate,
  tags,
  type,
  status,
  relatedBlog,
  relatedNote,
  source
} = entry.data

let relatedBlogPosts: CollectionEntry<'blog'>[] = []
if (relatedBlog && relatedBlog.length > 0) {
  const allBlogPosts = await getCollection('blog')
  relatedBlogPosts = allBlogPosts.filter((post) => relatedBlog.includes(post.id))
}

let relatedNoteEntries: CollectionEntry<'note'>[] = []
if (relatedNote && relatedNote.length > 0) {
  const allNotes = await getCollection('note')
  relatedNoteEntries = allNotes.filter(
    (note) => relatedNote.includes(note.id) && note.id !== entry.id
  )
}

const statusLabels: Record<string, string> = {
  'in-progress': '🚧 In Progress',
  incomplete: '⏸️ Incomplete',
  ready: '✅ Ready',
  archived: '📦 Archived'
}

const typeLabels: Record<string, string> = {
  note: '📝 Note',
  snippet: '💡 Snippet',
  draft: '✏️ Draft',
  idea: '🔮 Idea',
  research: '🔬 Research',
  reference: '📚 Reference'
}

const socialImage = heroImage
  ? typeof heroImage.src === 'string'
    ? heroImage.src
    : heroImage.src.src
  : undefined
const meta = {
  title,
  description: description || title,
  ogImage: socialImage
}
const primaryColor = accentColor ?? heroImage?.color ?? 'hsl(var(--primary) / var(--un-text-opacity))'
---

<PageLayout {meta} highlightColor={primaryColor} back='/note'>
  <div slot='header' class='animate gap-y-4'>
    {
      heroImage && (
        <div class='relative mb-6'>
          <Image
            alt={heroImage.alt || title}
            class='h-auto w-full max-w-[65ch] rounded-2xl object-contain'
            fetchpriority='high'
            loading='eager'
            {...heroImage}
          />
        </div>
      )
    }

    <div class='mb-2 flex flex-wrap items-center gap-2 text-sm text-muted-foreground'>
      <span class='rounded-md bg-muted px-2 py-1'>{typeLabels[type] || type}</span>
      <span class='rounded-md bg-muted px-2 py-1'>{statusLabels[status] || status}</span>
      {
        tags.length > 0 && (
          <>
            <span>·</span>
            {tags.map((tag) => (
              <a
                href={`/note/tags/${tag}`}
                class='rounded-md border border-border px-2 py-1 transition hover:border-foreground/20'
              >
                {tag}
              </a>
            ))}
          </>
        )
      }
    </div>

    <h1 class='mb-4 text-3xl font-bold leading-tight sm:text-4xl'>{title}</h1>

    {description && <p class='text-lg text-muted-foreground'>{description}</p>}

    <PageInfo class='mt-2 italic' />

    <div class='mt-4 flex flex-wrap items-center gap-4 text-sm text-muted-foreground'>
      <div class='flex items-center gap-2'>
        <Icon name='calendar' />
        <time datetime={date.toISOString()}>
          {
            date.toLocaleDateString('zh-CN', {
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            })
          }
        </time>
      </div>
      {
        updatedDate && (
          <div class='flex items-center gap-2'>
            <Icon name='calendar' />
            <span>
              Updated{' '}
              {updatedDate.toLocaleDateString('zh-CN', {
                year: 'numeric',
                month: 'long',
                day: 'numeric'
              })}
            </span>
          </div>
        )
      }
    </div>

    {
      source && (
        <div class='mt-4 flex items-start gap-2 rounded-lg bg-muted/50 p-3 text-sm'>
          <span class='mt-0.5 shrink-0 text-muted-foreground'>🔗</span>
          <div>
            <span class='text-muted-foreground'>Source: </span>
            <a href={source} target='_blank' rel='noopener noreferrer' class='hover:underline'>
              {source}
            </a>
          </div>
        </div>
      )
    }
  </div>

  <article class='prose prose-pure dark:prose-invert max-w-none'>
    <Content />
  </article>

  <div slot='bottom' class='animate mt-8 border-t border-border pt-6'>
    {(relatedBlogPosts.length > 0 || relatedNoteEntries.length > 0) && (
      <>
        <h2 class='mb-4 text-xl font-semibold'>Related Content</h2>

        {relatedBlogPosts.length > 0 && (
          <div class='mb-6'>
            <h3 class='mb-3 flex items-center gap-2 text-sm font-medium text-muted-foreground'>
              <span>📰</span>
              Blog Posts
            </h3>
            <ul class='space-y-2'>
              {relatedBlogPosts.map((post) => (
                <li>
                  <a
                    href={`/blog/${post.id}`}
                    class='block rounded-lg border border-border bg-card p-3 transition hover:border-foreground/20'
                    data-astro-prefetch
                  >
                    <div class='font-medium'>{post.data.title}</div>
                    {post.data.description && (
                      <p class='mt-1 text-sm text-muted-foreground'>{post.data.description}</p>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        {relatedNoteEntries.length > 0 && (
          <div class='mb-6'>
            <h3 class='mb-3 flex items-center gap-2 text-sm font-medium text-muted-foreground'>
              <span>🗂️</span>
              Related Notes
            </h3>
            <ul class='space-y-2'>
              {relatedNoteEntries.map((note) => (
                <li>
                  <a
                    href={`/note/${note.id}`}
                    class='block rounded-lg border border-border bg-card p-3 transition hover:border-foreground/20'
                    data-astro-prefetch
                  >
                    <div class='flex items-center gap-2'>
                      <span class='font-medium'>{note.data.title}</span>
                      <span class='text-xs text-muted-foreground'>
                        {typeLabels[note.data.type] || note.data.type}
                      </span>
                    </div>
                    {note.data.description && (
                      <p class='mt-1 text-sm text-muted-foreground'>{note.data.description}</p>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </>
    )}

    <div class='flex items-start justify-between gap-4 border-t border-border pt-6'>
      <div class='text-sm text-muted-foreground'>
        <p class='mb-2 flex items-center gap-2'>
          <span class='shrink-0'>🗂️</span>
          <span>This is a {typeLabels[type]?.toLowerCase() || type} in the knowledge base.</span>
        </p>
        <p class='text-xs'>Content may be incomplete or work-in-progress.</p>
      </div>
      <Button title='← Back' href='/note' variant='back' />
    </div>
  </div>
</PageLayout>
