---
import type { FriendLink, ResolvedLudusLayout } from '@/lib/links'

import config from '@/site-config'

interface Props {
  friend: FriendLink
  layout: ResolvedLudusLayout
  /** 入场错峰序号：pop 延迟与浮动相位都由它推导 */
  order?: number
}

const { friend, layout, order = 0 } = Astro.props
const avatar =
  (config.integ?.links?.cacheAvatar ?? false)
    ? (friend.avatar_cache?.path ?? friend.avatar)
    : friend.avatar
const style = [
  `--ludus-x:${layout.desktop.x}%`,
  `--ludus-y:${layout.desktop.y}%`,
  `--ludus-size:${layout.desktop.size}px`,
  `--ludus-mobile-x:${layout.mobile.x}%`,
  `--ludus-mobile-y:${layout.mobile.y}%`,
  `--ludus-mobile-size:${layout.mobile.size}px`,
  `--ludus-rotate:${layout.rotate}deg`,
  `--ludus-parallax-x:${layout.parallaxX}px`,
  `--ludus-parallax-y:${layout.parallaxY}px`,
  `--ludus-z:${layout.zIndex}`,
  `--ludus-order:${order}`
].join(';')
---

<a
  href={friend.link}
  target='_blank'
  rel='noopener noreferrer'
  class:list={['ludus-card', `ludus-label-${layout.labelSide}`]}
  style={style}
  aria-label={`访问 ${friend.name}`}
>
  {/* 浮动层单独一层：常驻上下漂浮不与 hover/入场的 transform 打架 */}
  <span class='ludus-float'>
    <span class='ludus-card-surface'>
      <img
        src={avatar}
        alt=''
        class='ludus-card-icon'
        width={layout.desktop.size}
        height={layout.desktop.size}
        loading='lazy'
        decoding='async'
      />
    </span>
  </span>
  <span class='ludus-tooltip'>
    <span class='ludus-label'>{friend.name}</span>
    <span class='ludus-description'>{friend.desc}</span>
  </span>
</a>

<style>
  .ludus-card {
    /* 生效几何统一走 --_x/--_y/--_size，移动端只需覆盖这三个变量 */
    --_x: var(--ludus-x);
    --_y: var(--ludus-y);
    --_size: var(--ludus-size);
    position: absolute;
    /* clamp 位置护栏：无论 links.json 坐标怎么写（哪怕 0%/100%），
       卡片中心都被留在舞台内侧半个卡身 + 6px，杜绝被 overflow:hidden 裁切 */
    top: clamp(calc(var(--_size) / 2 + 6px), var(--_y), calc(100% - var(--_size) / 2 - 6px));
    left: clamp(calc(var(--_size) / 2 + 6px), var(--_x), calc(100% - var(--_size) / 2 - 6px));
    z-index: var(--ludus-z);
    width: var(--_size);
    height: var(--_size);
    color: inherit;
    outline: none;
    transform: translate(-50%, -50%)
      translate(
        calc(var(--ludus-mouse-x, 0) * var(--ludus-parallax-x)),
        calc(var(--ludus-mouse-y, 0) * var(--ludus-parallax-y))
      )
      rotate(var(--ludus-rotate));
    /* 视差拖尾：慢出曲线让卡片带一点“惯性滑行”，比 180ms 直给柔和得多 */
    transition: transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* 常驻缓浮：时长与相位都由 order 推导，各卡不同步，像悬浮的玻璃片 */
  .ludus-float {
    display: block;
    width: 100%;
    height: 100%;
    animation: ludusFloat calc(5.2s + var(--ludus-order, 0) * 0.6s) ease-in-out
      calc(var(--ludus-order, 0) * -1.3s) infinite alternate;
  }
  @keyframes ludusFloat {
    from {
      transform: translateY(-3px);
    }
    to {
      transform: translateY(3px);
    }
  }

  .ludus-card-surface {
    display: grid;
    width: 100%;
    height: 100%;
    place-items: center;
    overflow: hidden;
    border: 1px solid var(--ludus-card-border);
    border-radius: 22px;
    background: var(--ludus-card-bg);
    filter: drop-shadow(0 10px 14px var(--ludus-card-shadow));
    transition:
      transform 380ms cubic-bezier(0.34, 1.56, 0.64, 1),
      border-radius 300ms ease,
      border-color 300ms ease,
      background-color 300ms ease,
      filter 300ms ease;
    /* 错峰弹簧入场：中心站点先出（见 LudusCta），友链依次 pop（backwards 保证延迟期不可见） */
    animation: ludusPop 0.65s cubic-bezier(0.34, 1.56, 0.64, 1)
      calc(0.24s + var(--ludus-order, 0) * 90ms) backwards;
  }
  @keyframes ludusPop {
    from {
      opacity: 0;
      transform: scale(0.3);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  /* hover 从“按下缩小”改为 visionOS 式“拾起”：放大 + 圆角变润 + 影子加深 */
  .ludus-card:hover .ludus-card-surface,
  .ludus-card.is-hovered .ludus-card-surface,
  .ludus-card:focus-visible .ludus-card-surface {
    border-color: var(--ludus-card-border-hover);
    border-radius: 30px;
    background: var(--ludus-card-bg-hover);
    filter: drop-shadow(0 18px 28px var(--ludus-card-shadow-hover));
    transform: scale(1.06);
  }

  .ludus-card:focus-visible .ludus-card-surface {
    outline: 2px solid hsl(var(--primary));
    outline-offset: 4px;
  }

  .ludus-card-icon {
    width: 80%;
    height: 80%;
    border-radius: 999px;
    object-fit: cover;
    pointer-events: none;
  }

  .ludus-tooltip {
    position: absolute;
    top: 44%;
    z-index: 10;
    display: flex;
    width: max-content;
    max-width: min(14rem, calc(100vw - 2rem));
    flex-direction: column;
    gap: 0.38rem;
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
    transition:
      opacity 200ms ease,
      visibility 0s linear 200ms,
      transform 320ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .ludus-label,
  .ludus-description {
    border: 1px solid var(--ludus-label-border);
    background: var(--ludus-label-bg);
    color: var(--ludus-label-color);
    box-shadow: 0 10px 22px var(--ludus-label-shadow);
  }

  .ludus-label {
    width: max-content;
    max-width: 9rem;
    overflow: hidden;
    border-radius: 999px;
    padding: 0.34rem 0.68rem;
    font-size: 0.78rem;
    font-weight: 500;
    line-height: 1;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .ludus-description {
    max-width: min(14rem, calc(100vw - 2rem));
    border-radius: 8px;
    padding: 0.48rem 0.62rem;
    font-size: 0.72rem;
    line-height: 1.45;
    overflow-wrap: anywhere;
  }

  .ludus-label-right .ludus-tooltip {
    left: calc(100% + 0.42rem);
    align-items: flex-start;
    transform: translate(-0.8rem, -58%) scale(0.9);
    transform-origin: left center;
  }

  .ludus-label-left .ludus-tooltip {
    right: calc(100% + 0.42rem);
    align-items: flex-end;
    transform: translate(0.8rem, -58%) scale(0.9);
    transform-origin: right center;
  }

  .ludus-card:hover .ludus-tooltip,
  .ludus-card.is-hovered .ludus-tooltip,
  .ludus-card:focus-visible .ludus-tooltip {
    opacity: 1;
    visibility: visible;
    transition-delay: 0s;
  }

  .ludus-label-right:hover .ludus-tooltip,
  .ludus-label-right.is-hovered .ludus-tooltip,
  .ludus-label-right:focus-visible .ludus-tooltip {
    transform: translate(0.18rem, -58%) scale(1);
  }

  .ludus-label-left:hover .ludus-tooltip,
  .ludus-label-left.is-hovered .ludus-tooltip,
  .ludus-label-left:focus-visible .ludus-tooltip {
    transform: translate(-0.18rem, -58%) scale(1);
  }

  @media (max-width: 768px) {
    .ludus-card {
      --_x: var(--ludus-mobile-x);
      --_y: var(--ludus-mobile-y);
      --_size: var(--ludus-mobile-size);
    }

    .ludus-tooltip {
      max-width: min(12rem, 72vw);
    }

    .ludus-description {
      max-width: min(12rem, 72vw);
      font-size: 0.68rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ludus-card {
      transform: translate(-50%, -50%) rotate(var(--ludus-rotate));
      transition: none;
    }

    .ludus-float,
    .ludus-card-surface {
      animation: none;
    }

    .ludus-card-surface,
    .ludus-tooltip {
      transition: none;
    }
  }
</style>
