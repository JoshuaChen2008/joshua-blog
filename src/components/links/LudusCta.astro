---
import { getLudusFriends, parseLinks } from '@/lib/links'
import rawLinks from '@/public/links.json'

import LudusCard from '@/components/links/LudusCard.astro'
import { siteLink } from '@/site-config'

const links = parseLinks(rawLinks)
const cards = getLudusFriends(links)
---

<section id='ludus-cta' class='ludus-section not-prose' aria-label='精选友链'>
  <div class='ludus-stage'>
    {cards.map(({ friend, layout }) => <LudusCard friend={friend} layout={layout} />)}

    <a class='ludus-center' href={siteLink.link} aria-label={`返回 ${siteLink.name} 首页`}>
      <span class='ludus-center-surface'>
        <img src='/images/avatar.webp' alt='' class='ludus-center-icon' width='88' height='88' />
      </span>
      <span class='ludus-center-label'>{siteLink.name}</span>
    </a>
  </div>
</section>

<style>
  .ludus-section {
    --ludus-card-bg: rgb(255 255 255 / 0.88);
    --ludus-card-bg-hover: rgb(255 255 255 / 0.98);
    --ludus-card-border: hsl(var(--border) / 0.76);
    --ludus-card-border-hover: hsl(var(--foreground) / 0.2);
    --ludus-card-shadow: rgb(15 23 42 / 0.14);
    --ludus-card-shadow-hover: rgb(15 23 42 / 0.2);
    --ludus-label-bg: rgb(255 255 255 / 0.94);
    --ludus-label-color: #050506;
    --ludus-label-border: hsl(var(--border) / 0.72);
    --ludus-label-shadow: rgb(15 23 42 / 0.12);
    position: relative;
    min-height: 560px;
    margin: 1.5rem auto 0;
    overflow: hidden;
    isolation: isolate;
  }

  .ludus-section::before {
    position: absolute;
    inset: 0;
    z-index: 0;
    content: '';
    pointer-events: none;
    background: radial-gradient(
      circle at 50% 50%,
      rgb(186 230 253 / 0.68) 0%,
      rgb(224 242 254 / 0.42) 22%,
      rgb(240 249 255 / 0.22) 42%,
      hsl(var(--background) / 1) 74%
    );
    mask-image: linear-gradient(to bottom, transparent 0%, #000 18%, #000 82%, transparent 100%);
  }

  :global(.dark) .ludus-section {
    --ludus-card-bg: rgb(24 24 28 / 0.72);
    --ludus-card-bg-hover: rgb(38 38 44 / 0.88);
    --ludus-card-border: rgb(255 255 255 / 0.14);
    --ludus-card-border-hover: rgb(255 255 255 / 0.28);
    --ludus-card-shadow: rgb(0 0 0 / 0.34);
    --ludus-card-shadow-hover: rgb(0 0 0 / 0.5);
    --ludus-label-bg: rgb(20 20 24 / 0.92);
    --ludus-label-color: hsl(var(--foreground));
    --ludus-label-border: rgb(255 255 255 / 0.16);
    --ludus-label-shadow: rgb(0 0 0 / 0.38);
  }

  :global(.dark) .ludus-section::before {
    background: radial-gradient(
      circle at 50% 50%,
      rgb(255 255 255 / 0.18) 0%,
      rgb(125 211 252 / 0.13) 18%,
      rgb(14 40 62 / 0.52) 44%,
      hsl(var(--background) / 1) 78%
    );
  }

  .ludus-stage {
    --ludus-mouse-x: 0;
    --ludus-mouse-y: 0;
    position: absolute;
    inset: 72px 0 96px;
    z-index: 1;
    max-width: 58rem;
    margin-inline: auto;
  }

  .ludus-center {
    position: absolute;
    top: 50%;
    left: 50%;
    z-index: 5;
    width: 88px;
    height: 88px;
    color: inherit;
    outline: none;
    transform: translate(-50%, -50%)
      translate(calc(var(--ludus-mouse-x) * 6px), calc(var(--ludus-mouse-y) * 6px));
    transition: transform 200ms ease-out;
  }

  .ludus-center-surface {
    display: grid;
    width: 100%;
    height: 100%;
    place-items: center;
    overflow: hidden;
    border: 1px solid var(--ludus-card-border);
    border-radius: 24px;
    background: var(--ludus-card-bg);
    filter: drop-shadow(0 12px 18px var(--ludus-card-shadow));
    transition:
      transform 200ms ease,
      border-radius 220ms ease,
      filter 220ms ease;
  }

  .ludus-center:hover .ludus-center-surface,
  .ludus-center.is-hovered .ludus-center-surface,
  .ludus-center:focus-visible .ludus-center-surface {
    border-radius: 36px;
    filter: drop-shadow(0 16px 26px var(--ludus-card-shadow-hover));
    transform: scale(0.94);
  }

  .ludus-center:focus-visible .ludus-center-surface {
    outline: 2px solid hsl(var(--primary));
    outline-offset: 4px;
  }

  .ludus-center-icon {
    width: 80%;
    height: 80%;
    border-radius: 999px;
    object-fit: cover;
  }

  .ludus-center-label {
    position: absolute;
    bottom: calc(100% + 0.62rem);
    left: 50%;
    width: max-content;
    max-width: 12rem;
    overflow: hidden;
    border: 1px solid var(--ludus-label-border);
    border-radius: 999px;
    background: var(--ludus-label-bg);
    padding: 0.34rem 0.68rem;
    color: var(--ludus-label-color);
    font-size: 0.78rem;
    line-height: 1;
    opacity: 0;
    pointer-events: none;
    text-overflow: ellipsis;
    visibility: hidden;
    white-space: nowrap;
    box-shadow: 0 10px 22px var(--ludus-label-shadow);
    transform: translate(-50%, 0.8rem) scale(0.9);
    transition:
      opacity 180ms ease,
      visibility 0s linear 180ms,
      transform 240ms ease-out;
  }

  .ludus-center:hover .ludus-center-label,
  .ludus-center.is-hovered .ludus-center-label,
  .ludus-center:focus-visible .ludus-center-label {
    opacity: 1;
    visibility: visible;
    transform: translate(-50%, -0.18rem) scale(1);
    transition-delay: 0s;
  }

  @media (max-width: 768px) {
    .ludus-section {
      min-height: 520px;
    }

    .ludus-stage {
      inset: 56px 0 80px;
    }

    .ludus-center {
      width: 68px;
      height: 68px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ludus-center {
      transform: translate(-50%, -50%);
      transition: none;
    }

    .ludus-center-surface,
    .ludus-center-label {
      transition: none;
    }
  }
</style>

<script>
  const section = document.querySelector<HTMLElement>('#ludus-cta')
  const stage = section?.querySelector<HTMLElement>('.ludus-stage')
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)')

  if (section && stage && !reduceMotion.matches) {
    const freezeHoverCards = stage.querySelectorAll<HTMLElement>('.ludus-card, .ludus-center')

    section.addEventListener('mousemove', (event) => {
      const rect = section.getBoundingClientRect()
      stage.style.setProperty(
        '--ludus-mouse-x',
        String(((event.clientX - rect.left) / rect.width) * 2 - 1)
      )
      stage.style.setProperty(
        '--ludus-mouse-y',
        String(((event.clientY - rect.top) / rect.height) * 2 - 1)
      )
    })

    section.addEventListener('mouseleave', () => {
      stage.style.setProperty('--ludus-mouse-x', '0')
      stage.style.setProperty('--ludus-mouse-y', '0')
    })

    freezeHoverCards.forEach((card) => {
      card.addEventListener('mouseenter', () => {
        const transform = getComputedStyle(card).transform

        if (transform && transform !== 'none') {
          const matrix = new DOMMatrixReadOnly(transform)
          card.style.transform = `matrix(${matrix.a}, ${matrix.b}, ${matrix.c}, ${matrix.d}, ${matrix.e}, ${matrix.f})`
        }

        card.classList.add('is-hovered')
      })

      card.addEventListener('mouseleave', () => {
        card.style.transform = ''
        card.classList.remove('is-hovered')
      })
    })
  }
</script>
