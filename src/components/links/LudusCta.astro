---
import codexIcon from '@/assets/tools/codex.svg?url'
import claudeIcon from '@/assets/tools/simple-icons--claude.svg?url'
import cursorIcon from '@/assets/tools/vscode1.svg?url'
import devinIcon from '@/assets/tools/anti.svg?url'
import geminiIcon from '@/assets/tools/ri--gemini-fill.svg?url'
import grokIcon from '@/assets/tools/arcticons--openai-chatgpt.svg?url'
import ludusIcon from '@/assets/tools/ludus.svg?url'

const cards = [
  {
    className: 'im-cta-photo-1',
    href: 'https://openai.com/index/codex/',
    label: 'Codex',
    icon: codexIcon
  },
  {
    className: 'im-cta-photo-2',
    href: 'https://claude.ai',
    label: 'Claude',
    icon: claudeIcon
  },
  {
    className: 'im-cta-photo-3',
    href: 'https://cursor.com',
    label: 'Cursor',
    icon: cursorIcon
  },
  {
    className: 'im-cta-photo-4',
    href: 'https://devin.ai',
    label: 'Devin',
    icon: devinIcon
  },
  {
    className: 'im-cta-photo-5',
    href: 'https://gemini.google.com',
    label: 'Gemini',
    icon: geminiIcon
  },
  {
    className: 'im-cta-photo-6',
    href: 'https://grok.com',
    label: 'Grok',
    icon: grokIcon
  }
]
---

<section id='ludus-cta' class='im-section im-bottom-cta not-prose'>
  <div class='im-bottom-cta-wrap'>
    <div class='im-bottom-cta-media'>
      {
        cards.map((card) => (
          <button
            class={`im-cta-photo ${card.className}`}
            type='button'
            data-url={card.href}
            aria-label={`Open ${card.label}`}
          >
            <img src={card.icon} alt='' class='im-cta-icon' loading='lazy' />
          </button>
        ))
      }

      <button
        class='im-center-card'
        type='button'
        data-url='https://ludus.my'
        aria-label='Open Ludus'
      >
        <img src={ludusIcon} alt='' class='im-cta-icon' loading='lazy' />
      </button>
    </div>
  </div>
</section>

<style>
  .im-section {
    width: 100%;
    margin: 1.5rem auto 0;
    padding: 64px 0 56px;
  }

  .im-bottom-cta {
    position: relative;
    z-index: 2;
    min-height: 560px;
    overflow: hidden;
    background: transparent;
    padding-top: 72px;
    padding-bottom: 96px;
  }

  .im-bottom-cta-wrap {
    position: relative;
    min-height: 392px;
  }

  .im-bottom-cta-media {
    --im-mouse-x: 0;
    --im-mouse-y: 0;
    position: absolute;
    inset: 0;
    z-index: 1;
    max-width: 58rem;
    margin-inline: auto;
  }

  .im-cta-photo,
  .im-center-card {
    position: absolute;
    display: grid;
    place-items: center;
    border: 1px solid hsl(var(--border) / 0.76);
    background: rgb(255 255 255 / 0.9);
    color: #050506;
    cursor: pointer;
    filter: drop-shadow(0 10px 14px rgb(0 0 0 / 0.12));
    transition:
      transform 0.18s ease-out,
      border-radius 0.35s ease,
      filter 0.35s ease,
      border-color 0.35s ease,
      background-color 0.35s ease;
  }

  .im-cta-photo {
    width: 96px;
    height: 96px;
    border-radius: 22px;
    transform:
      translate(
        calc(var(--im-mouse-x) * var(--im-px, 30px)),
        calc(var(--im-mouse-y) * var(--im-py, 30px))
      )
      rotate(var(--im-rot, 0deg));
  }

  .im-cta-icon {
    width: 70%;
    height: 70%;
    object-fit: contain;
    border-radius: 999px;
    pointer-events: none;
  }

  .im-cta-photo.is-hovered,
  .im-center-card.is-hovered {
    border-color: hsl(var(--foreground) / 0.2);
    background: #fff;
    filter: drop-shadow(0 14px 22px rgb(0 0 0 / 0.18));
  }

  .im-cta-photo.is-hovered {
    border-radius: 34px;
  }

  .im-cta-photo-1 {
    --im-px: -60px;
    --im-py: 40px;
    --im-rot: 7deg;
    top: 6%;
    left: 16%;
  }

  .im-cta-photo-2 {
    --im-px: 80px;
    --im-py: -40px;
    --im-rot: -8deg;
    top: 7%;
    right: 16%;
  }

  .im-cta-photo-3 {
    --im-px: -35px;
    --im-py: -50px;
    --im-rot: -5deg;
    top: 42%;
    left: 8%;
    width: 78px;
    height: 78px;
  }

  .im-cta-photo-4 {
    --im-px: 50px;
    --im-py: 42px;
    --im-rot: 7deg;
    top: 48%;
    right: 8%;
    width: 78px;
    height: 78px;
  }

  .im-cta-photo-5 {
    --im-px: 62px;
    --im-py: -62px;
    --im-rot: -11deg;
    left: 22%;
    bottom: -10%;
    width: 112px;
    height: 112px;
  }

  .im-cta-photo-6 {
    --im-px: -55px;
    --im-py: 45px;
    --im-rot: 12deg;
    right: 22%;
    bottom: -14%;
    width: 112px;
    height: 112px;
  }

  .im-center-card {
    top: 50%;
    left: 50%;
    z-index: 3;
    width: 88px;
    height: 88px;
    margin: -44px 0 0 -44px;
    border-radius: 24px;
    transform: translate(calc(var(--im-mouse-x) * 6px), calc(var(--im-mouse-y) * 6px));
    transition:
      transform 0.25s ease-out,
      border-radius 0.35s ease,
      filter 0.35s ease,
      border-color 0.35s ease,
      background-color 0.35s ease;
  }

  .im-center-card.is-hovered {
    border-radius: 36px;
    filter: drop-shadow(0 16px 26px rgb(0 0 0 / 0.18));
  }

  @media (max-width: 768px) {
    .im-section {
      width: 100%;
      padding: 56px 0;
    }

    .im-bottom-cta {
      min-height: 520px;
      padding-bottom: 80px;
    }

    .im-cta-photo-1 {
      top: 30%;
      left: -42px;
    }

    .im-cta-photo-2 {
      top: 30%;
      right: -42px;
    }

    .im-cta-photo-3 {
      top: 3%;
      left: -10px;
    }

    .im-cta-photo-4 {
      top: 4%;
      right: -12px;
    }

    .im-cta-photo-5 {
      left: -12px;
      bottom: -18px;
    }

    .im-cta-photo-6 {
      right: -12px;
      bottom: -18px;
    }

    .im-center-card {
      width: 68px;
      height: 68px;
      margin: -34px 0 0 -34px;
    }
  }
</style>

<script is:inline>
  ;(() => {
    const section = document.getElementById('ludus-cta')
    const media = section?.querySelector('.im-bottom-cta-media')

    if (!section || !media) return

    section.addEventListener('mousemove', (event) => {
      const rect = section.getBoundingClientRect()
      media.style.setProperty('--im-mouse-x', ((event.clientX - rect.left) / rect.width) * 2 - 1)
      media.style.setProperty('--im-mouse-y', ((event.clientY - rect.top) / rect.height) * 2 - 1)
    })

    section.addEventListener('mouseleave', () => {
      media.style.setProperty('--im-mouse-x', '0')
      media.style.setProperty('--im-mouse-y', '0')
    })

    const allCards = media.querySelectorAll('.im-cta-photo, .im-center-card')

    allCards.forEach((card) => {
      card.addEventListener('click', () => {
        const url = card.getAttribute('data-url')
        if (url) window.open(url, '_blank', 'noopener,noreferrer')
      })

      card.addEventListener('mouseenter', () => {
        const transform = getComputedStyle(card).transform
        const matrix = transform === 'none' ? new DOMMatrixReadOnly() : new DOMMatrixReadOnly(transform)
        const angle = Math.atan2(matrix.m21, matrix.m11) * (180 / Math.PI)

        card.style.transform = `translate(${matrix.m41.toFixed(1)}px, ${matrix.m42.toFixed(
          1
        )}px) rotate(${angle.toFixed(1)}deg) scale(0.92)`
        card.classList.add('is-hovered')
      })

      card.addEventListener('mouseleave', () => {
        card.style.transform = ''
        card.classList.remove('is-hovered')
      })
    })
  })()
</script>
