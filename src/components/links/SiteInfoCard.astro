---
import { formatFriendYaml } from '@/lib/links'
import type { FriendLink } from '@/lib/links'

interface Props {
  site: Pick<FriendLink, 'name' | 'desc' | 'link' | 'avatar'>
}

const { site } = Astro.props
const yaml = formatFriendYaml(site)
const displayAvatar = new URL(site.avatar).pathname
---

<section
  class='not-prose overflow-hidden rounded-2xl border bg-card'
  aria-labelledby='site-link-title'
>
  <div class='flex flex-col gap-4 p-4 sm:flex-row sm:items-center sm:p-5'>
    <img
      src={displayAvatar}
      alt={`${site.name} 的头像`}
      width='80'
      height='80'
      class='h-16 w-16 rounded-2xl object-cover sm:h-20 sm:w-20'
    />
    <div class='min-w-0 flex-1'>
      <h3 id='site-link-title' class='m-0 text-base font-medium'>{site.name}</h3>
      <p class='mb-0 mt-1 text-sm text-muted-foreground'>{site.desc}</p>
      <a
        href={site.link}
        class='mt-2 inline-block break-all text-xs text-muted-foreground underline-offset-4 hover:underline'
      >
        {site.link}
      </a>
    </div>
  </div>

  <div class='border-t bg-muted/40 p-4 sm:p-5'>
    <div class='mb-3 flex items-center justify-between gap-3'>
      <p class='m-0 text-sm font-medium'>标准友链格式</p>
      <button
        type='button'
        class='min-h-11 cursor-pointer rounded-lg border bg-background px-3 text-sm transition-colors duration-200 hover:bg-muted focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary'
        data-site-info-copy={yaml}
      >
        复制全部
      </button>
    </div>
    <pre
      class='m-0 overflow-x-auto rounded-xl border bg-background p-3 text-xs leading-relaxed'><code>{yaml}</code></pre>
  </div>
</section>

<script>
  const copyButton = document.querySelector<HTMLButtonElement>('[data-site-info-copy]')

  copyButton?.addEventListener('click', async () => {
    const text = copyButton.dataset.siteInfoCopy
    if (!text) return

    try {
      await navigator.clipboard.writeText(text)
      document.dispatchEvent(
        new CustomEvent('toast', { detail: { message: '本站友链信息已复制' } })
      )
    } catch {
      document.dispatchEvent(
        new CustomEvent('toast', { detail: { message: '复制失败，请手动复制代码块' } })
      )
    }
  })
</script>
