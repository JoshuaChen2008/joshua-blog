---
import { Image } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'
import { statusColors, statusLabels, typeColors, typeLabels } from '@/lib/noteMeta'

interface Props {
  entry: CollectionEntry<'note'>
}

const { entry } = Astro.props
---

<li
  class='note-preview'
  style={entry.data.heroImage?.color &&
    `--preview-highlight:color-mix(in srgb,${entry.data.heroImage.color} 40%,hsl(var(--foreground)/var(--un-text-opacity,1)));
    --preview-highlight-bg:hsl(from ${entry.data.heroImage.color} h s l/20%)`}
>
  <a
    href={`/note/${entry.id}`}
    class:list={[
      `group block
    relative
    w-full
    overflow-hidden
    rounded-xl
    border
    border-border
    bg-card
    px-5
    py-5
    transition-colors
    ease-in-out
    hover:border-foreground/20
    hover:bg-muted
    hover:text-primary
    hover:shadow-sm`
    ]}
    data-astro-prefetch
  >
    {
      entry.data.heroImage && (
        <Image
          alt={entry.data.heroImage.alt || entry.data.title}
          class='note-cover-image absolute end-0 top-0 z-0 h-full w-full rounded-xl object-cover opacity-50 transition-opacity duration-300 group-hover:opacity-70 md:w-3/5'
          loading='eager'
          {...entry.data.heroImage}
        />
      )
    }

    <div class='relative flex items-start justify-between gap-4' style='z-index:1'>
      <div
        class:list={[
          'min-w-0 flex-1 space-y-2',
          entry.data.heroImage && 'md:max-w-[62%]'
        ]}
      >
        <h3
          class='text-lg font-medium leading-tight transition-colors group-hover:text-primary'
        >
          {entry.data.title}
        </h3>
        {
          entry.data.description && (
            <p class='text-sm leading-6 text-muted-foreground'>{entry.data.description}</p>
          )
        }

        <div class='flex flex-wrap items-center gap-x-2 gap-y-2 text-xs text-muted-foreground'>
          <span class={`rounded-md px-2 py-0.5 font-medium ${typeColors[entry.data.type]}`}>
            {typeLabels[entry.data.type] || entry.data.type}
          </span>
          <span>·</span>
          <time datetime={entry.data.date.toISOString()}>
            {
              entry.data.date.toLocaleDateString('zh-CN', {
                year: 'numeric',
                month: 'short',
                day: 'numeric'
              })
            }
          </time>
          {
            entry.data.updatedDate && (
              <span>
                · 更新于{' '}
                {entry.data.updatedDate.toLocaleDateString('zh-CN', {
                  month: 'short',
                  day: 'numeric'
                })}
              </span>
            )
          }
          {
            entry.data.tags.length > 0 && (
              <>
                <span>·</span>
                <div class='flex flex-wrap gap-1.5'>
                  {entry.data.tags.map((tag: string) => (
                    <span class='rounded-md bg-muted px-2 py-0.5'>{tag}</span>
                  ))}
                </div>
              </>
            )
          }
          <span>·</span>
          <span>
            <span class='waline-pageview-readonly' data-path={`/note/${entry.id}`}> 0 </span>{' '}
            views
          </span>
        </div>
      </div>

      <span
        class={`mt-0.5 shrink-0 rounded-md px-2 py-1 text-xs font-medium ${statusColors[entry.data.status]}`}
      >
        {statusLabels[entry.data.status]}
      </span>

      <svg
        xmlns='http://www.w3.org/2000/svg'
        width='16'
        height='16'
        viewBox='0 0 24 24'
        fill='none'
        stroke-width='2.5'
        stroke-linecap='round'
        stroke-linejoin='round'
        class='preview-redirect absolute bottom-0 end-0 my-1 stroke-muted-foreground group-hover:stroke-primary'
        aria-hidden='true'
      >
        <line
          x1='5'
          y1='12'
          x2='19'
          y2='12'
          class='translate-x-4 scale-x-0 transition-all duration-300 ease-in-out group-hover:translate-x-1 group-hover:scale-x-100'
        ></line>
        <polyline
          points='12 5 19 12 12 19'
          class='translate-x-0 transition-all duration-300 ease-in-out group-hover:translate-x-1'
        ></polyline>
      </svg>
    </div>
  </a>

  <style>
    .note-preview {
      --preview-highlight-final: var(
        --preview-highlight,
        hsl(var(--primary) / var(--un-text-opacity, 1))
      );
    }

    .note-preview:hover {
      & > a {
        background-color: var(
          --preview-highlight-bg,
          hsl(var(--muted) / var(--un-bg-opacity, 1))
        ) !important;
        color: var(--preview-highlight-final) !important;
      }

      & > a .preview-redirect {
        stroke: var(--preview-highlight-final) !important;
      }
    }

    .note-cover-image {
      -webkit-mask-image: linear-gradient(
        to right,
        rgba(0, 0, 0, 0) 0%,
        rgba(0, 0, 0, 1) 100%
      );
      mask-image: linear-gradient(
        to right,
        rgba(0, 0, 0, 0) 0%,
        rgba(0, 0, 0, 1) 100%
      );
    }
  </style>
</li>
